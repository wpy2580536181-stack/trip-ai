# 上下文管理数据流 (Context Management Data Flow)
# D2 渲染: d2 context-data-flow.d2 context-data-flow.svg

direction: right

# ── 输入与历史 ───────────────────────────────────
user_msg: User message {
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1976d2"
  style.bold: true
}

history: Message history\n(MySQL) {
  shape: cylinder
  style.fill: "#fff3e0"
  style.stroke: "#f57c00"
}

token_counter: Token counter\ncurrent usage {
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
}

# ── 决策点 ───────────────────────────────────────
budget: Token budget check\nHISTORY_MAX_TOKENS = 8000 {
  shape: diamond
  style.fill: "#fff9c4"
  style.stroke: "#f9a825"
  style.stroke-width: 2
  style.font-size: 14
}

# ── 三条分支 ────────────────────────────────────
keep: Within budget\nKeep all messages {
  shape: rectangle
  style.fill: "#c8e6c9"
  style.stroke: "#388e3c"
}

summarize: Approaching limit\nSummarize old msgs {
  shape: rectangle
  style.fill: "#ffe0b2"
  style.stroke: "#f57c00"
}

compress: Exceeded\nCompressor\ncompressConversation() {
  shape: rectangle
  style.fill: "#ffcdd2"
  style.stroke: "#c62828"
  style.bold: true
}

# ── 压缩管线 ────────────────────────────────────
summary_cache: Summary cache\nin-memory {
  shape: cylinder
  style.fill: "#e1bee7"
  style.stroke: "#7b1fa2"
}

llm_call: LLM call\nwith compressed context {
  shape: cloud
  style.fill: "#f3e5f5"
  style.stroke: "#7b1fa2"
  style.bold: true
}

# ── 数据流 ──────────────────────────────────────
user_msg -> history: "save"
history -> token_counter: "load & count"
token_counter -> budget: "tokens"

budget -> keep: "within" {
  style.stroke: "#388e3c"
  style.stroke-width: 2
}
budget -> summarize: "approaching" {
  style.stroke: "#f57c00"
  style.stroke-width: 2
}
budget -> compress: "exceeded" {
  style.stroke: "#c62828"
  style.stroke-width: 2
  style.bold: true
}

summarize -> summary_cache: "store" {
  style.stroke: "#7b1fa2"
}
summary_cache -> compress: "load" {
  style.stroke: "#7b1fa2"
}

keep -> llm_call: "full history" {
  style.stroke: "#388e3c"
  style.stroke-width: 2
}
compress -> llm_call: "compressed" {
  style.stroke: "#c62828"
  style.stroke-width: 2
  style.bold: true
}
