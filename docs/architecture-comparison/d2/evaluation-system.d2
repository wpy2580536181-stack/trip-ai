# 评估体系 (Evaluation System)
# D2 渲染: d2 evaluation-system.d2 evaluation-system.svg

direction: down

# ── 输入 ─────────────────────────────────────────
fixtures: Fixtures\nfixtures/*.yaml +\nfixtures/generated/*.yaml {
  shape: page
  style.fill: "#fff3e0"
  style.stroke: "#f57c00"
  style.bold: true
}

# ── 入口 ─────────────────────────────────────────
entry: CLI / API entry\neval · evalApi {
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1976d2"
}

# ── 核心 ─────────────────────────────────────────
runner: Runner {
  shape: hexagon
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  style.stroke-width: 2
  style.bold: true
}

# ── 4 种模式 ─────────────────────────────────────
modes: 4 Modes\nmock · real ·\nmulti-sample · report {
  shape: rectangle
  style.fill: "#e1f5fe"
  style.stroke: "#0277bd"
}

# ── 13 个评估器 ─────────────────────────────────
evaluators: 13 Evaluators\nmust_contain_keywords · must_not ·\nregex · json_schema · ... {
  shape: rectangle
  style.fill: "#f3e5f5"
  style.stroke: "#7b1fa2"
  style.bold: true
}

# ── LLM ─────────────────────────────────────────
llm: LLM\nmock or real {
  shape: cloud
  style.fill: "#f3e5f5"
  style.stroke: "#7b1fa2"
}

# ── 输出 ────────────────────────────────────────
output: Output\nJSON report ·\nHTML report · score {
  shape: page
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  style.bold: true
}

# ── 反馈回路 ─────────────────────────────────────
feedback: Feedback Loop\nnegative feedback →\nfixtureConverter →\nnew YAML fixture {
  shape: package
  style.fill: "#ffcdd2"
  style.stroke: "#c62828"
  style.bold: true
}

# ── 主链路 ──────────────────────────────────────
fixtures -> entry: "load" {
  style.stroke: "#f57c00"
  style.stroke-width: 2
}
entry -> runner: "run" {
  style.stroke: "#1976d2"
  style.stroke-width: 2
  style.bold: true
}
runner -> modes: "select" {
  style.stroke: "#388e3c"
  style.stroke-width: 2
}
modes -> evaluators: "execute" {
  style.stroke: "#0277bd"
  style.stroke-width: 2
}

evaluators <-> llm: "judge" {
  style.stroke: "#7b1fa2"
  style.stroke-width: 2
  style.bold: true
}
evaluators -> output: "aggregate" {
  style.stroke: "#7b1fa2"
  style.stroke-width: 2
}

# ── 反馈环 (自闭合) ─────────────────────────────
output -> feedback: "negative samples" {
  style.stroke: "#c62828"
  style.stroke-width: 2
  style.bold: true
}
feedback -> fixtures: "append new YAML" {
  style.stroke: "#c62828"
  style.stroke-width: 2
  style.bold: true
}
