# 系统架构图 (System Architecture)
# D2 渲染: d2 system-architecture.d2 system-architecture.svg

direction: down

# ── Frontend 层 ─────────────────────────────────
frontend: Vue 3 + Vite\n+ Pinia + Element Plus {
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1976d2"
  style.stroke-width: 2
  style.font-color: "#0d47a1"
  style.bold: true
}

# ── Backend 层 ──────────────────────────────────
backend: Express 5\n+ Prisma + Pino {
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  style.stroke-width: 2
  style.font-color: "#1b5e20"
  style.bold: true
}

# ── Data 层 (cylinders) ─────────────────────────
mysql: MySQL 8\n(via Prisma) {
  shape: cylinder
  style.fill: "#fff3e0"
  style.stroke: "#f57c00"
  style.stroke-width: 2
}

redis: Redis 7 {
  shape: cylinder
  style.fill: "#fff3e0"
  style.stroke: "#f57c00"
  style.stroke-width: 2
}

chroma: Chroma\nVector DB {
  shape: cylinder
  style.fill: "#fff3e0"
  style.stroke: "#f57c00"
  style.stroke-width: 2
}

# ── AI 服务 (clouds) ────────────────────────────
llm: DeepSeek\ndeepseek-v4-flash {
  shape: cloud
  style.fill: "#f3e5f5"
  style.stroke: "#7b1fa2"
  style.stroke-width: 2
  style.font-color: "#4a148c"
  style.bold: true
}

embed: bge-small-zh\nEmbedding {
  shape: cloud
  style.fill: "#f3e5f5"
  style.stroke: "#7b1fa2"
  style.stroke-width: 2
  style.font-color: "#4a148c"
  style.bold: true
}

# ── Connections ─────────────────────────────────
frontend -> backend: "HTTPS · REST + SSE" {
  style.stroke: "#1976d2"
  style.stroke-width: 3
  style.font-size: 14
  style.bold: true
}

backend -> mysql: "Prisma ORM" {
  style.stroke: "#388e3c"
  style.stroke-width: 2
}
backend -> redis: "ioredis\nstreamStore · rate limit · stats" {
  style.stroke: "#388e3c"
  style.stroke-width: 2
}
backend -> chroma: "vector search" {
  style.stroke: "#388e3c"
  style.stroke-width: 2
}
backend -> llm: "chat completion" {
  style.stroke: "#7b1fa2"
  style.stroke-width: 2
  style.font-size: 14
}
backend -> embed: "embed via LangChain" {
  style.stroke: "#7b1fa2"
  style.stroke-width: 2
}
