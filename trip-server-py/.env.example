# 数据库配置
DATABASE_URL=mysql://root:root@localhost:3306/trip_db

# JWT 配置
JWT_SECRET=change-this-to-a-random-secret-string
JWT_EXPIRES_IN_DAYS=7

# 服务配置（开发期用 8000，与 Node.js 3000 并存）
PORT=8000
CORS_ORIGIN=http://localhost:5173
CORS_DEMO=true

# 大模型配置
MODEL_PROVIDER=DEEPSEEK
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 环境配置
NODE_ENV=development

# Chroma 向量数据库（注意：Chroma 容器映射 8001:8000，所以这里填 8001）
CHROMA_URL=http://localhost:8001

# HuggingFace 模型下载镜像
HF_ENDPOINT=https://hf-mirror.com/

# 高德 MCP
AMAP_MAPS_API_KEY=your_amap_api_key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Redis 配置
REDIS_URL=redis://localhost:6379

# Token 预算配置
TOKEN_BUDGET_USER=50000
TOKEN_BUDGET_GLOBAL=200000

# 并发守卫配置
CONCURRENCY_GLOBAL=10
CONCURRENCY_USER=1
