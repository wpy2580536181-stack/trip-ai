{
  "name": "trip-server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "ts-node prisma/seed.ts",
    "seed:knowledge": "ts-node prisma/seed-knowledge.ts",
    "seed:poi": "ts-node prisma/seed-poi.ts",
    "migrate": "npx prisma db push",
    "eval": "ts-node --project tsconfig.eval.json eval/run.ts",
    "eval:real": "ts-node --project tsconfig.eval.json eval/run.ts --real",
    "eval:cleanup": "ts-node --project tsconfig.eval.json eval/cleanup.ts",
    "eval:typecheck": "tsc --project tsconfig.eval.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "@prisma/client": "^5.22.0",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^3.0.3",
    "chromadb": "^3.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.11.1",
    "js-yaml": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pino-http": "^5.8.4",
    "chalk": "^5.6.2",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@langchain/core": "^1.1.48"
  }
}
