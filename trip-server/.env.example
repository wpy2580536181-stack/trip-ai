# 数据库配置 — 修改为你的 MySQL 连接信息
DATABASE_URL="mysql://<user>:<password>@localhost:3306/trip_db"

# JWT 配置 — 请更换为一个随机字符串
JWT_SECRET=change-this-to-a-random-secret-string
JWT_EXPIRES_IN=7d

# 服务配置
PORT=3000
CORS_ORIGIN=http://localhost:5173

# 大模型配置 — 任选一个 provider 填入对应密钥
MODEL_PROVIDER=DEEPSEEK

# KIMI_API_KEY=your-kimi-api-key
# KIMI_BASE_URL=https://api.kimi.cn/v1
# KIMI_MODEL=kimi-for-coding

# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# 环境配置
NODE_ENV=development

# Chroma 向量数据库
CHROMA_URL=http://localhost:8000
CHROMA_PERSIST_DIR=./chroma_data

# HuggingFace 模型下载镜像（默认走国内镜像；如部署在海外可设为 https://huggingface.co/）
HF_ENDPOINT=https://hf-mirror.com/

# Amap (高德) MCP
export AMAP_MAPS_API_KEY=your_amap_api_key
export UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# =============================================================================
# LLM 并发控制 & Token 预算
# =============================================================================

# LangGraph 并发控制
LLM_GLOBAL_CONCURRENCY=10
LLM_USER_CONCURRENCY=1

# Token 预算限制（可选，有默认值）
USER_TOKEN_LIMIT=50000
GLOBAL_TOKEN_LIMIT=200000
USER_TOKEN_WINDOW_MS=3600000
GLOBAL_TOKEN_WINDOW_MS=60000

# =============================================================================
# 速率限制器存储配置
# =============================================================================

# 速率限制器存储类型（memory / redis）
# - memory: 使用内存存储（默认，适合单进程部署）
# - redis: 使用 Redis 存储（适合集群部署，跨进程共享计数器）
RATE_LIMIT_STORE=memory

# Redis 配置（仅当 RATE_LIMIT_STORE=redis 时需要）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
